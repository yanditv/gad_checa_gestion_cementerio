generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(uuid())
  identificationNumber String    @unique
  firstName            String
  lastName             String
  email                String    @unique
  passwordHash         String
  phone                String?
  address              String?
  identificationType   String
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime? @updatedAt

  userRoles UserRole[]
}

model Role {
  id               String  @id @default(uuid())
  name             String  @unique
  normalizedName   String  @unique
  permissions      String?

  users UserRole[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model Cemetery {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  email     String?
  taxId     String?
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)

  blocks Block[]
}

model Block {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  cemeteryId String
  cemetery   Cemetery  @relation(fields: [cemeteryId], references: [id])

  floors Floor[]
  vaults Vault[]
}

model Floor {
  id          String  @id @default(uuid())
  number      Int
  description String?
  isActive    Boolean @default(true)

  blockId String
  block   Block  @relation(fields: [blockId], references: [id])

  vaults Vault[]
}

model Vault {
  id           String   @id @default(uuid())
  number       String
  capacity     Int
  type         String?
  isActive     Boolean  @default(true)
  notes        String?
  location     String?
  price        Decimal  @db.Decimal(18, 2)
  rentalPrice  Decimal  @db.Decimal(18, 2)
  createdAt    DateTime @default(now())

  blockId String
  block   Block  @relation(fields: [blockId], references: [id])
  floorId String?
  floor   Floor? @relation(fields: [floorId], references: [id])

  ownerId String?
  owner   Owner? @relation(fields: [ownerId], references: [id])

  contracts Contract[]
  deceased  Deceased[]
}

model Person {
  id                   String    @id @default(uuid())
  identificationNumber String
  firstName            String
  lastName             String
  phone                String?
  email                String?
  address              String?
  identificationType   String
  birthDate            DateTime?
  gender               String?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  personType           String    @default("Person")

  responsibleParties ResponsibleParty[]
  owners             Owner[]

  @@unique([identificationNumber, personType])
}

model Owner {
  id        String   @id @default(uuid())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  personId String @unique
  person   Person @relation(fields: [personId], references: [id])

  vaults           Vault[]
  responsibleParty ResponsibleParty?
}

model ResponsibleParty {
  id           String   @id @default(uuid())
  relationship String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  personId String
  person   Person @relation(fields: [personId], references: [id])

  ownerId String? @unique
  owner   Owner? @relation(fields: [ownerId], references: [id])

  contracts Contract[]
}

model Deceased {
  id                   String    @id @default(uuid())
  firstName            String
  lastName             String
  identificationNumber String?
  birthDate            DateTime?
  deathDate            DateTime?
  burialDate           DateTime?
  causeOfDeath         String?
  notes                String?
  age                  Int?
  gender               String?
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())

  vaultId String
  vault   Vault  @relation(fields: [vaultId], references: [id])

  contracts Contract[]
}

model Contract {
  id                 String    @id @default(uuid())
  sequentialNumber   String    @unique
  startDate          DateTime
  endDate            DateTime?
  monthCount         Int
  totalAmount        Decimal   @db.Decimal(18, 2)
  isActive           Boolean   @default(true)
  notes              String?
  signedDocumentPath String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime? @updatedAt

  vaultId String
  vault   Vault  @relation(fields: [vaultId], references: [id])

  responsiblePartyId String?
  responsibleParty   ResponsibleParty? @relation(fields: [responsiblePartyId], references: [id])

  deceasedId String?
  deceased   Deceased? @relation(fields: [deceasedId], references: [id])

  sourceContractId String?
  sourceContract   Contract?  @relation("ContractSource", fields: [sourceContractId], references: [id])
  childContracts   Contract[] @relation("ContractSource")

  relatedContractId String?
  relatedContract   Contract?  @relation("RelatedContract", fields: [relatedContractId], references: [id])
  relatedContracts  Contract[] @relation("RelatedContract")

  installments Installment[]
}

model Installment {
  id              String    @id @default(uuid())
  number          Int
  amount          Decimal   @db.Decimal(18, 2)
  dueDate         DateTime
  paidAt          DateTime?
  interestAmount  Decimal   @default(0) @db.Decimal(18, 2)
  isActive        Boolean   @default(true)
  notes           String?

  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])

  installmentPayments InstallmentPayment[]
}

model Payment {
  id            String   @id @default(uuid())
  receiptNumber String   @unique
  amount        Decimal  @db.Decimal(18, 2)
  paidAt        DateTime
  paymentMethod String
  reference     String?
  note          String?
  isActive      Boolean  @default(true)
  bankId        String?
  bank          Bank?    @relation(fields: [bankId], references: [id])

  installmentPayments InstallmentPayment[]
}

model InstallmentPayment {
  installmentId String
  paymentId     String
  installment   Installment @relation(fields: [installmentId], references: [id])
  payment       Payment     @relation(fields: [paymentId], references: [id])

  @@id([installmentId, paymentId])
}

model Discount {
  id          String    @id @default(uuid())
  name        String
  percentage  Decimal   @db.Decimal(5, 2)
  description String?
  isActive    Boolean   @default(true)
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  entityName String
  entityId   String
  action     String
  actorId    String?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([entityName, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model Bank {
  id       String   @id @default(uuid())
  name     String   @unique
  account  String?
  isActive Boolean  @default(true)

  payments Payment[]
}

model GovernmentInfo {
  id      String  @id @default(uuid())
  name    String
  address String
  phone   String
  email   String
  taxId   String
  logo    String?
  slogan  String?
}
